
{
  "name": "Fully Translator",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Quickly translate fully page",
  "background": {
    "service_worker": "public/background.js"
  },
  "permissions": ["contextMenus", "storage", "tabs"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["public/contentScript.js"],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "run-translate": {
      "description": "Translate Page",
      "suggested_key": {
        "default": "Alt+T"
      }
    }
  },
	"action": {
		"default_title": "Fully Translator",
		"default_popup": "popup.html"
  }
}